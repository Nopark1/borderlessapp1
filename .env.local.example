# Copy this file to ".env.local" and fill in the values from your Supabase project
# (Supabase dashboard → Project Settings → API). NEVER commit .env.local.
#
# These two are safe to expose to the browser (the anon key is protected by
# Row-Level Security):
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Secret — used only by server-side admin scripts (e.g. seeding). NEVER expose
# this to the browser and never commit it. (Optional for Phase 2.)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
